# =============================================
# Root environment template (sample only)
# =============================================
# Copy this file to `.env` and set real values.
# Never commit real secrets to Git.
#
# What these do:
# - SERVERPOD_PASSWORD_database: PostgreSQL password used by backend server config.
# - RESEND_API_KEY: API key for email sending via Resend.
# - ALLOW_CONSOLE_OTP_FALLBACK: true হলে development এ OTP console এ দেখা যাবে.

SERVERPOD_PASSWORD_database=your_postgres_password_here
RESEND_API_KEY=re_replace_with_your_real_key
ALLOW_CONSOLE_OTP_FALLBACK=true
